---
import { Image } from 'astro:assets';
import heroManicure from "@/assets/img/hero-manicure.webp";
import heroMasaje from "@/assets/img/hero-masaje.webp";
import heroPeeling from "@/assets/img/hero-peeling.webp";

// Definimos tamaños para que el navegador sepa qué descargar
const imageSizes = "(max-width: 640px) 100vw, (max-width: 1024px) 33vw, 420px";
---

<section id="inicio" data-animate-section="hero" class="relative flex min-h-dvh flex-col overflow-hidden px-4 pb-5 pt-3 select-none md:px-8 md:pb-10 md:pt-4">

    <div class="relative z-10 mx-auto flex w-full max-w-7xl flex-1 items-stretch justify-center pt-18 md:items-center md:pt-24">
        <div class="flex min-h-[calc(100dvh-6.5rem)] w-full max-w-5xl flex-col justify-between rounded-4xl border border-outline/70 bg-surface/72 px-5 py-6 text-center shadow-[0_18px_50px_rgba(154,123,79,0.08)] backdrop-blur-[2px] sm:px-8 sm:py-10 md:px-12 md:py-12">

            <h1 data-hero-title class="mt-3 font-headline text-[clamp(2.05rem,9vw,3.1rem)] leading-[1.02] tracking-[-0.03em] text-on-surface sm:mt-4 md:text-[clamp(1.35rem,4.6vw,2.95rem)]">
                La ciencia de la belleza
                <span class="mt-1 block font-normal italic text-on-surface-variant">el arte del cuidado</span>
            </h1>

            <div data-hero-badge class="mx-auto mt-5 inline-flex items-center gap-3 rounded-full border border-primary/70 bg-primary-container px-4 py-2 shadow-[0_10px_24px_rgba(154,123,79,0.1)]">
                <span class="h-2 w-2 rounded-full bg-primary"></span>
                <p class="m-0 font-detail text-[0.58rem] font-bold uppercase tracking-[0.2em] text-on-surface sm:text-[0.64rem]">
                    Estándar de excelencia
                </p>
            </div>

            <div class="mx-auto mt-8 grid w-full max-w-96 grid-cols-1 gap-3 sm:mt-7 sm:max-w-120 sm:grid-cols-3 md:max-w-180 md:gap-4 lg:max-w-3xl lg:gap-5">
                
                <figure data-hero-thumb class="group m-0 overflow-hidden rounded-2xl border border-outline/80 bg-surface/80 shadow-[0_12px_24px_rgba(154,123,79,0.12)] aspect-420/236">
                    <Image 
                        src={heroManicure} 
                        alt="Manicure en Spabella Stetic" 
                        width={420} 
                        height={236} 
                        fetchpriority="high" 
                        loading="eager" 
                        sizes={imageSizes}
                        class="h-full w-full object-cover transition duration-300 group-hover:scale-115 group-hover:saturate-110" 
                    />
                </figure>

                <figure data-hero-thumb class="group m-0 overflow-hidden rounded-2xl border border-outline/80 bg-surface/80 shadow-[0_12px_24px_rgba(154,123,79,0.12)] aspect-420/236">
                    <Image 
                        src={heroMasaje} 
                        alt="Masaje en Spabella Stetic" 
                        width={420} 
                        height={236} 
                        loading="lazy" 
                        sizes={imageSizes}
                        class="h-full w-full object-cover transition duration-300 group-hover:scale-105 group-hover:saturate-110" 
                    />
                </figure>
                
                <figure data-hero-thumb class="group m-0 overflow-hidden rounded-2xl border border-outline/80 bg-surface/80 shadow-[0_12px_24px_rgba(154,123,79,0.12)] aspect-420/236">
                    <Image 
                        src={heroPeeling} 
                        alt="Peeling en Spabella Stetic" 
                        width={420} 
                        height={236} 
                        loading="lazy" 
                        sizes={imageSizes}
                        class="h-full w-full object-cover transition duration-300 group-hover:scale-105 group-hover:saturate-110" 
                    />
                </figure>
            </div>
        </div>
    </div>
</section>