---
import ImportedTreatments from "@/components/ImportedTreatments.astro";
import HifuFeature from "@/components/HifuFeature.astro";
import LaserFeature from "@/components/LaserFeature.astro";
import ServiceCard from "@/components/ServiceCard.astro";
import tratamientos from "@/data/tratamientos";
---

<section class="px-4 py-[clamp(3.2rem,7vw,5.8rem)] md:px-8 lg:px-10" id="servicios">
    <div class="mx-auto grid w-full max-w-330 gap-5">
        
        <LaserFeature />
        <HifuFeature />

        <section class="mt-5 grid grid-cols-1 gap-3 sm:grid-cols-2 xl:grid-cols-3 2xl:grid-cols-5">
            {tratamientos.map((t) => (
                <ServiceCard 
                    category={t.category} 
                    title={t.title} 
                    description={t.description} 
                    image={t.image} 
                    alt={t.alt} 
                />
            ))}
        </section>

        <ImportedTreatments />
    </div>
</section>