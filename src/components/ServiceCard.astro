---
interface Props {
    category: string;
    title: string;
    description: string;
    image: string;
    alt: string;
}

const { category, title, description, image, alt } = Astro.props;

const whatsappNumber = '584247394782';
const whatsappMessage = `Hola, me interesa el tratamiento ${title}. Podrian darme informacion, por favor?`;
const whatsappHref = `https://wa.me/${whatsappNumber}?text=${encodeURIComponent(whatsappMessage)}`;
---

<article
    class="service-card-shell group relative overflow-hidden rounded-3xl border border-outline/75 bg-surface/80 p-2 backdrop-blur-md transition-[background-color,border-color] duration-300 hover:border-primary/65 hover:bg-primary-container/70 active:border-primary/65 active:bg-primary-container/70"
    data-service-card
>
    <div aria-hidden="true" class="service-card-sheen pointer-events-none absolute inset-x-6 top-0 h-px bg-linear-to-r from-transparent via-primary/55 to-transparent opacity-70"></div>

    <figure
        class="m-0 aspect-4/3 w-full overflow-hidden rounded-xl border border-outline/70 transition-[border-color] duration-300 sm:aspect-5/4 xl:aspect-4/3 group-hover:border-primary/60 group-active:border-primary/60"
        data-gallery-item
    >
        <img
            src={image}
            alt={alt}
            class="h-full w-full object-cover transition duration-300 group-hover:scale-107 group-hover:saturate-110 group-active:scale-104"
        />
    </figure>

    <p class="font-detail mt-3 text-[0.62rem] font-extrabold uppercase tracking-[0.16em] text-primary">{category}</p>
    <h3 class="font-headline mt-1 text-[clamp(1.05rem,1.8vw,1.34rem)] leading-[1.15] text-on-surface">{title}</h3>
    <p class="mt-2 text-[0.83rem] leading-6 text-on-surface-variant">{description}</p>

    <div
        class="mt-3 max-h-0 translate-y-4 overflow-hidden opacity-0 pointer-events-none transition-all duration-300 group-hover:max-h-16 group-hover:translate-y-0 group-hover:opacity-100 group-hover:pointer-events-auto group-active:max-h-16 group-active:translate-y-0 group-active:opacity-100 group-active:pointer-events-auto"
        data-service-panel
    >
        <a
            href={whatsappHref}
            target="_blank"
            rel="noreferrer"
            class="touch-manipulation inline-flex w-full items-center justify-center rounded-xl border border-primary/70 bg-primary px-3 py-2 text-center text-[0.68rem] uppercase tracking-[0.14em] text-on-primary transition duration-300 hover:brightness-105 active:scale-[0.98]"
            data-service-cta
        >
            Información
        </a>
    </div>
</article>

<script>
    const root = document.body;

    if (!root.dataset.serviceCardTapInit) {
        root.dataset.serviceCardTapInit = 'true';

        const isTouchMode = () => window.matchMedia('(hover: none), (pointer: coarse)').matches;

        const hidePanel = (card: HTMLElement) => {
            const panel = card.querySelector<HTMLElement>('[data-service-panel]');
            if (!panel) return;

            card.dataset.open = 'false';
            panel.classList.remove('max-h-16', 'translate-y-0', 'opacity-100', 'pointer-events-auto');
            panel.classList.add('max-h-0', 'translate-y-4', 'opacity-0', 'pointer-events-none');
        };

        const showPanel = (card: HTMLElement) => {
            const panel = card.querySelector<HTMLElement>('[data-service-panel]');
            if (!panel) return;

            card.dataset.open = 'true';
            panel.classList.remove('max-h-0', 'translate-y-4', 'opacity-0', 'pointer-events-none');
            panel.classList.add('max-h-16', 'translate-y-0', 'opacity-100', 'pointer-events-auto');
        };

        document.addEventListener('click', (event) => {
            if (!isTouchMode()) return;

            const target = event.target;
            if (!(target instanceof Element)) return;

            const card = target.closest<HTMLElement>('[data-service-card]');
            const cta = target.closest<HTMLElement>('[data-service-cta]');

            if (cta) return;

            if (!card) {
                document.querySelectorAll<HTMLElement>('[data-service-card][data-open="true"]').forEach((openCard) => {
                    hidePanel(openCard);
                });
                return;
            }

            const isOpen = card.dataset.open === 'true';

            document.querySelectorAll<HTMLElement>('[data-service-card][data-open="true"]').forEach((openCard) => {
                if (openCard !== card) hidePanel(openCard);
            });

            if (isOpen) {
                hidePanel(card);
            } else {
                showPanel(card);
            }
        });
    }
</script>

<style>
    @keyframes serviceCardSheen {
        0%,
        100% {
            transform: translate3d(-12%, 0, 0);
            opacity: 0.28;
        }
        50% {
            transform: translate3d(12%, 0, 0);
            opacity: 0.72;
        }
    }

    .service-card-shell {
        isolation: isolate;
    }

    .service-card-sheen {
        animation: serviceCardSheen 5.8s ease-in-out infinite;
    }

    @media (prefers-reduced-motion: reduce) {
        .service-card-sheen {
            animation: none;
        }
    }
</style>
