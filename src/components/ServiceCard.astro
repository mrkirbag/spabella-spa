---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
    category: string;
    title: string;
    description: string;
    image: ImageMetadata;
    alt: string;
}

const { category, title, description, image, alt } = Astro.props;

const whatsappNumber = '584247394782';
const whatsappMessage = `Hola, me interesa el tratamiento ${title}. ¿Podrían darme información, por favor?`;
const whatsappHref = `https://wa.me/${whatsappNumber}?text=${encodeURIComponent(whatsappMessage)}`;
const [firstWord = '', ...restWords] = description.split(' ');
const remainingDescription = restWords.join(' ');
---

<article
    class="service-card-shell group relative overflow-hidden rounded-3xl border border-outline/75 bg-surface/80 p-2 backdrop-blur-md transition-[background-color,border-color] duration-300 hover:border-primary/65 hover:bg-primary-container/70"
    data-service-card
>
    <div aria-hidden="true" class="service-card-sheen pointer-events-none absolute inset-x-6 top-0 h-px bg-linear-to-r from-transparent via-primary/55 to-transparent opacity-70"></div>

    <figure
        class="m-0 relative w-full overflow-hidden rounded-xl border border-outline/70 transition-[border-color] duration-300 aspect-4/3 bg-surface-variant/50"
        data-gallery-item
    >
        <div
            aria-hidden="true"
            class="pointer-events-none absolute inset-0 z-10 bg-black/65 opacity-0 transition-opacity duration-300 group-hover:opacity-100"
            data-service-dim
        ></div>

        <Image
            src={image}
            alt={alt}
            width={540}
            height={405}
            sizes="(max-width: 640px) 100vw, (max-width: 1280px) 50vw, 20vw"
            quality={75}
            loading="lazy"
            decoding="async"
            class="h-full w-full object-cover transition duration-500 will-change-transform group-hover:scale-110"
            data-service-image
        />

        <figcaption
            class="pointer-events-none absolute inset-0 z-20 flex items-center justify-center p-4 text-center opacity-0 transition-opacity duration-300 group-hover:opacity-100"
            data-service-description
        >
            <p class="max-w-[90%] rounded-xl border border-primary/40 bg-black/35 px-3 py-2 text-[0.84rem] leading-6 text-white shadow-lg backdrop-blur-[1px]">
                <span class="font-headline font-semibold italic text-primary">{firstWord}</span>{remainingDescription ? ` ${remainingDescription}` : ''}
            </p>
        </figcaption>
    </figure>

    <div class="p-2">
        <p class="font-detail mt-3 text-[0.62rem] font-extrabold uppercase tracking-[0.16em] text-primary">{category}</p>
        <h3 class="font-headline mt-1 text-[clamp(1.05rem,1.8vw,1.34rem)] leading-[1.15] text-on-surface">{title}</h3>
        <div
            class="mt-3 max-h-0 translate-y-2 overflow-hidden opacity-0 pointer-events-none transition-all duration-300 group-hover:max-h-16 group-hover:translate-y-0 group-hover:opacity-100 group-hover:pointer-events-auto"
            data-service-panel
        >
            <a
                href={whatsappHref}
                target="_blank"
                rel="noreferrer"
                class="inline-flex w-full items-center justify-center rounded-xl border border-primary/70 bg-primary px-3 py-2 text-center text-[0.68rem] uppercase tracking-[0.14em] text-on-primary transition hover:brightness-105 active:scale-[0.98]"
                data-service-cta
            >
                Información
            </a>
        </div>
    </div>
</article>

<script>
    const root = document.body;

    if (!root.dataset.serviceCardTapInit) {
        root.dataset.serviceCardTapInit = 'true';

        const isTouchMode = () => window.matchMedia('(hover: none), (pointer: coarse)').matches;

        const hidePanel = (card: HTMLElement) => {
            const panel = card.querySelector<HTMLElement>('[data-service-panel]');
            const dimLayer = card.querySelector<HTMLElement>('[data-service-dim]');
            const descriptionLayer = card.querySelector<HTMLElement>('[data-service-description]');
            const image = card.querySelector<HTMLElement>('[data-service-image]');
            if (!panel) return;

            card.dataset.open = 'false';
            panel.classList.remove('max-h-16', 'translate-y-0', 'opacity-100', 'pointer-events-auto');
            panel.classList.add('max-h-0', 'translate-y-2', 'opacity-0', 'pointer-events-none');

            dimLayer?.classList.remove('opacity-100');
            dimLayer?.classList.add('opacity-0');

            descriptionLayer?.classList.remove('opacity-100');
            descriptionLayer?.classList.add('opacity-0');

            image?.classList.remove('scale-110');
        };

        const showPanel = (card: HTMLElement) => {
            const panel = card.querySelector<HTMLElement>('[data-service-panel]');
            const dimLayer = card.querySelector<HTMLElement>('[data-service-dim]');
            const descriptionLayer = card.querySelector<HTMLElement>('[data-service-description]');
            const image = card.querySelector<HTMLElement>('[data-service-image]');
            if (!panel) return;

            card.dataset.open = 'true';
            panel.classList.remove('max-h-0', 'translate-y-2', 'opacity-0', 'pointer-events-none');
            panel.classList.add('max-h-16', 'translate-y-0', 'opacity-100', 'pointer-events-auto');

            dimLayer?.classList.remove('opacity-0');
            dimLayer?.classList.add('opacity-100');

            descriptionLayer?.classList.remove('opacity-0');
            descriptionLayer?.classList.add('opacity-100');

            image?.classList.add('scale-110');
        };

        document.addEventListener('click', (event) => {
            if (!isTouchMode()) return;

            const target = event.target;
            if (!(target instanceof Element)) return;

            const card = target.closest<HTMLElement>('[data-service-card]');
            const cta = target.closest<HTMLElement>('[data-service-cta]');

            if (cta) return;

            if (!card) {
                document.querySelectorAll<HTMLElement>('[data-service-card][data-open="true"]').forEach((openCard) => {
                    hidePanel(openCard);
                });
                return;
            }

            const isOpen = card.dataset.open === 'true';

            document.querySelectorAll<HTMLElement>('[data-service-card][data-open="true"]').forEach((openCard) => {
                if (openCard !== card) hidePanel(openCard);
            });

            if (isOpen) {
                hidePanel(card);
            } else {
                showPanel(card);
            }
        });
    }
</script>