---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
    category: string;
    title: string;
    description: string;
    image: ImageMetadata;
    alt: string;
}

const { category, title, description, image, alt } = Astro.props;

const whatsappNumber = '584247394782';
const whatsappMessage = `Hola, me interesa el tratamiento ${title}. ¿Podrían darme información, por favor?`;
const whatsappHref = `https://wa.me/${whatsappNumber}?text=${encodeURIComponent(whatsappMessage)}`;
---

<article
    class="service-card-shell group relative overflow-hidden rounded-3xl border border-outline/75 bg-surface/80 p-2 backdrop-blur-md transition-[background-color,border-color] duration-300 hover:border-primary/65 hover:bg-primary-container/70"
    data-service-card
>
    <div aria-hidden="true" class="service-card-sheen pointer-events-none absolute inset-x-6 top-0 h-px bg-linear-to-r from-transparent via-primary/55 to-transparent opacity-70"></div>

    <figure
        class="m-0 w-full overflow-hidden rounded-xl border border-outline/70 transition-[border-color] duration-300 aspect-4/3 bg-surface-variant/50"
        data-gallery-item
    >
        <Image
            src={image}
            alt={alt}
            width={540}
            height={405}
            sizes="(max-width: 640px) 100vw, (max-width: 1280px) 50vw, 20vw"
            quality={75}
            loading="lazy"
            decoding="async"
            class="h-full w-full object-cover transition duration-500 will-change-transform group-hover:scale-105"
        />
    </figure>

    <div class="p-2">
        <p class="font-detail mt-3 text-[0.62rem] font-extrabold uppercase tracking-[0.16em] text-primary">{category}</p>
        <h3 class="font-headline mt-1 text-[clamp(1.05rem,1.8vw,1.34rem)] leading-[1.15] text-on-surface">{title}</h3>
        <p class="mt-2 text-[0.83rem] leading-6 text-on-surface-variant">{description}</p>

        <div class="mt-3 overflow-hidden transition-all duration-300 max-h-0 opacity-0 group-hover:max-h-16 group-hover:opacity-100">
            <a
                href={whatsappHref}
                target="_blank"
                rel="noreferrer"
                class="inline-flex w-full items-center justify-center rounded-xl border border-primary/70 bg-primary px-3 py-2 text-center text-[0.68rem] uppercase tracking-[0.14em] text-on-primary transition hover:brightness-105 active:scale-[0.98]"
            >
                Información
            </a>
        </div>
    </div>
</article>