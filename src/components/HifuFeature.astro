---
import hifuImage from "@/assets/tratamientos/hifu.webp";

const whatsappNumber = '584247394782';
const whatsappMessage = 'Hola, me interesa el tratamiento HIFU 22D Max facial y corporal. ¿Podrían brindarme información, por favor?';
const whatsappHref = `https://wa.me/${whatsappNumber}?text=${encodeURIComponent(whatsappMessage)}`;
---

<section class="mt-5 grid gap-4 lg:grid-cols-2 lg:items-stretch">
    <figure class="group relative w-full min-h-[clamp(240px,34vw,390px)] overflow-hidden rounded-3xl border border-outline/75 bg-surface-variant/50 aspect-4/3 lg:aspect-auto lg:h-full">
        <img
            src={hifuImage.src}
            alt="HIFU 22D Max en Spabella Stetic"
            width={540}
            height={405}
            loading="lazy"
            decoding="async"
            class="absolute inset-0 block min-h-full min-w-full object-cover object-center transition duration-300 will-change-transform group-hover:scale-105"
        />
        <figcaption class="font-detail absolute bottom-3 left-3 rounded-full bg-primary-container px-3 py-2 text-[0.62rem] uppercase text-on-surface z-10">
            HIFU 22D Max premium
        </figcaption>
    </figure>

    <div class="flex h-full flex-col rounded-3xl border border-outline/75 bg-surface/80 p-[clamp(1.1rem,2.2vw,1.9rem)] backdrop-blur-md lg:justify-center" data-reveal>
        <p class="font-detail m-0 inline-flex w-fit self-start items-center rounded-full border border-primary/35 bg-primary-container/80 px-2.5 py-1 text-[0.58rem] font-extrabold uppercase tracking-[0.2em] text-primary">
            Tecnología Avanzada
        </p>
        <h3 class="font-headline mt-2 text-[clamp(1.3rem,2.5vw,2rem)] leading-[1.1] text-on-surface">HIFU 22D Max</h3>
        <p class="mt-3 text-[0.9rem] leading-6 text-on-surface-variant">
            Tratamiento facial y corporal no invasivo para mejorar firmeza, definición y regeneración visible de la piel.
        </p>

        <ul class="mt-4 grid gap-3">
            <li class="flex items-start gap-2.5 text-[0.84rem] leading-5.5 text-on-surface-variant">
                <span class="service-star-bullet mt-1 inline-flex h-4 w-4 shrink-0 items-center justify-center rounded-full border border-primary/70 bg-primary-container text-[0.6rem] text-primary">✦</span>
                <span>Precisión multinivel: energía focalizada para trabajar distintas capas con control.</span>
            </li>
            <li class="flex items-start gap-2.5 text-[0.84rem] leading-5.5 text-on-surface-variant">
                <span class="service-star-bullet mt-1 inline-flex h-4 w-4 shrink-0 items-center justify-center rounded-full border border-primary/70 bg-primary-container text-[0.6rem] text-primary">✦</span>
                <span>Resultados progresivos: mejora de firmeza y textura durante las semanas posteriores.</span>
            </li>
            <li class="flex items-start gap-2.5 text-[0.84rem] leading-5.5 text-on-surface-variant">
                <span class="service-star-bullet mt-1 inline-flex h-4 w-4 shrink-0 items-center justify-center rounded-full border border-primary/70 bg-primary-container text-[0.6rem] text-primary">✦</span>
                <span>Protocolo personalizado: zonas y parámetros ajustados según tu valoración inicial.</span>
            </li>
        </ul>

        <a
            href={whatsappHref}
            target="_blank"
            rel="noreferrer"
            class="touch-manipulation mt-6 inline-flex w-fit rounded-full bg-primary px-7 py-3 text-[10px] uppercase tracking-widest text-on-primary transition-transform duration-300 ease-[cubic-bezier(0.2,0.8,0.2,1)] will-change-transform hover:-translate-y-1 active:-translate-y-1 active:scale-[0.99] lg:px-10"
        >
            Reserva ahora
        </a>
    </div>
</section>
